# -*- shell-script -*-

# emacs tramp
[[ "$-" == *i* ]] || { unsetopt zle && PS1='%m$ ' && return; }

# get man, git log, etc. not to use more/less in an Emacs shell
if [ -n "$INSIDE_EMACS" ]
then
  # bracketed paste
  unset    zle_bracketed_paste
  unsetopt ZLE CORRECT

  # env variables
  export MANPAGER=cat
  export PAGER=cat
  export TERM=ansi
  # 2026-06-25 revisit this in a bit and see whether there's a
  # different way to avoid those annoying ansi escape sequences
  export TERM=dumb

  grep --version | grep GNU > /dev/null && alias grep='command grep --color=auto'
  ls   --version | grep GNU > /dev/null && alias ls='command   ls   --color=auto'
  diff --version | grep GNU > /dev/null && alias diff='command diff --color=auto'
fi

# make zsh aware of ssh-agent
UID="$(id -u teichman)"
export SSH_AUTH_SOCK="/run/user/$UID/ssh-agent.socket"
